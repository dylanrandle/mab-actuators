#!/bin/bash

set -e

CAN_ID=$1
CONFIG_FILE=$2

# Input validation
if [ -z "$CAN_ID" ] || [ -z "$CONFIG_FILE" ]; then
    echo "Usage: $0 <CAN_ID> <PATH_TO_CONFIG_FILE>"
    exit 1
fi

if [ ! -f "$CONFIG_FILE" ]; then
    echo "Error: Config file '$CONFIG_FILE' does not exist."
    exit 1
fi

# 1. Clear any existing errors on the drive
candletool md clear --id "$CAN_ID"

sleep 2

# 2. Log the current version of the MD device
candletool md version --id "$CAN_ID"

sleep 2

# 3. Update firmware to the latest version
candletool md update latest --recovery --id "$CAN_ID"

echo "Waiting..."
sleep 5

# 4. Reboot the device
candletool md reset --id "$CAN_ID"

echo "Waiting..."
sleep 5

# 5. Apply the configuration file 
candletool md config upload "$CONFIG_FILE" --id "$CAN_ID"

echo "Waiting..."
sleep 5

# 6. Save the base configuration to the MD80's flash memory
candletool md save --id "$CAN_ID"

echo "Waiting..."
sleep 5

# 7. Run the full calibration sequence
# WARNING: Ensure the motor shaft is completely free of any load before this runs!
candletool md calibration --id "$CAN_ID"

echo "Waiting..."
sleep 5

# 8. Save again to store the newly calculated calibration offsets to flash memory
candletool md save --id "$CAN_ID"

echo "Successfully provisioned and calibrated MD80 at CAN ID: $CAN_ID"
